<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<SplitPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.hms.controller.PatientController"
           dividerPositions="0.62" VBox.vgrow="ALWAYS">

    <!-- LEFT: Table pane -->
    <VBox spacing="10">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

        <Label text="Patient Management" styleClass="page-title"/>

        <HBox spacing="8" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="🔍  Search by name or phone…" prefWidth="300"/>
            <Button text="↻ Refresh" fx:id="btnRefresh" onAction="#onRefresh"/>
        </HBox>

        <TableView fx:id="patientTable" VBox.vgrow="ALWAYS"
                  >
            <columns>
                <TableColumn fx:id="colId"        text="ID"         minWidth="60"/>
                <TableColumn fx:id="colFirstName"  text="First Name" minWidth="120"/>
                <TableColumn fx:id="colLastName"   text="Last Name"  minWidth="120"/>
                <TableColumn fx:id="colDOB"        text="DOB"        minWidth="100"/>
                <TableColumn fx:id="colGender"     text="Gender"     minWidth="70"/>
                <TableColumn fx:id="colBlood"      text="Blood"      minWidth="60"/>
                <TableColumn fx:id="colPhone"      text="Phone"      minWidth="110"/>
                <TableColumn fx:id="colPStatus"    text="Status"     minWidth="70"/>
            </columns>
            <placeholder><Label text="No patients found."/></placeholder>
        </TableView>

        <Button text="🗑 Deactivate Selected" fx:id="btnDeactivate" onAction="#onDeactivate"
                styleClass="btn-danger"/>
    </VBox>

    <!-- RIGHT: Form pane -->
    <VBox spacing="10">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

        <Label text="Patient Details" styleClass="section-title"/>

        <GridPane hgap="8" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="110"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="First Name"    GridPane.rowIndex="0" styleClass="form-label"/>
            <TextField fx:id="tfFirst" promptText="First Name *"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Last Name"     GridPane.rowIndex="1" styleClass="form-label"/>
            <TextField fx:id="tfLast"  promptText="Last Name *"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Date of Birth" GridPane.rowIndex="2" styleClass="form-label"/>
            <DatePicker fx:id="dpDOB"   GridPane.rowIndex="2" GridPane.columnIndex="1"
                        maxWidth="Infinity"/>

            <Label text="Gender"        GridPane.rowIndex="3" styleClass="form-label"/>
            <ComboBox fx:id="cbGender"  GridPane.rowIndex="3" GridPane.columnIndex="1"
                      promptText="Gender *" maxWidth="Infinity"/>

            <Label text="Blood Group"   GridPane.rowIndex="4" styleClass="form-label"/>
            <TextField fx:id="tfBlood" promptText="Blood Group"
                       GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="Phone"         GridPane.rowIndex="5" styleClass="form-label"/>
            <TextField fx:id="tfPhone" promptText="Phone *"
                       GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <Label text="Email"         GridPane.rowIndex="6" styleClass="form-label"/>
            <TextField fx:id="tfEmail" promptText="Email"
                       GridPane.rowIndex="6" GridPane.columnIndex="1"/>

            <Label text="Address"       GridPane.rowIndex="7" styleClass="form-label"/>
            <TextField fx:id="tfAddress" promptText="Address"
                       GridPane.rowIndex="7" GridPane.columnIndex="1"/>

            <Label text="Emergency"     GridPane.rowIndex="8" styleClass="form-label"/>
            <TextField fx:id="tfEmergency" promptText="Emergency Contact"
                       GridPane.rowIndex="8" GridPane.columnIndex="1"/>
        </GridPane>

        <HBox spacing="10">
            <Button text="💾 Save"   fx:id="btnSave"  onAction="#onSave"  styleClass="btn-success"/>
            <Button text="✖ Clear"   fx:id="btnClear" onAction="#onClear" styleClass="btn-secondary"/>
        </HBox>
    </VBox>
</SplitPane>

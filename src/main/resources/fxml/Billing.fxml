<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<SplitPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.hms.controller.BillingController"
           dividerPositions="0.60" VBox.vgrow="ALWAYS">

    <!-- LEFT: Table pane -->
    <VBox spacing="10">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

        <Label text="Billing &amp; Payments" styleClass="page-title"/>

        <TableView fx:id="billTable" VBox.vgrow="ALWAYS"
                  >
            <columns>
                <TableColumn fx:id="colBillId"   text="Bill ID"    minWidth="60"/>
                <TableColumn fx:id="colBillPat"  text="Patient"    minWidth="160"/>
                <TableColumn fx:id="colBillDate" text="Date"       minWidth="90"/>
                <TableColumn fx:id="colConsult"  text="Consult(₹)" minWidth="90"/>
                <TableColumn fx:id="colMeds"     text="Meds(₹)"    minWidth="90"/>
                <TableColumn fx:id="colLab"      text="Lab(₹)"     minWidth="80"/>
                <TableColumn fx:id="colTotal"    text="Total(₹)"   minWidth="90"/>
                <TableColumn fx:id="colDiscount" text="Discount"   minWidth="70"/>
                <TableColumn fx:id="colNet"      text="Net(₹)"     minWidth="90"/>
                <TableColumn fx:id="colBStatus"  text="Status"     minWidth="70"/>
            </columns>
            <placeholder><Label text="No bills found."/></placeholder>
        </TableView>

        <HBox spacing="8">
            <Button text="↻ Refresh"        fx:id="btnRefresh" onAction="#onRefresh"/>
            <Button text="💳 Record Payment" fx:id="btnPay"     onAction="#onRecordPayment"
                    styleClass="btn-primary"/>
        </HBox>
    </VBox>

    <!-- RIGHT: Form pane -->
    <VBox spacing="10">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

        <Label text="Generate Bill" styleClass="section-title"/>

        <GridPane hgap="8" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="100"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Patient"      GridPane.rowIndex="0" styleClass="form-label"/>
            <ComboBox fx:id="cbPatient" GridPane.rowIndex="0" GridPane.columnIndex="1"
                      promptText="Select Patient *" maxWidth="Infinity"/>

            <Label text="Consult Fee"  GridPane.rowIndex="1" styleClass="form-label"/>
            <TextField fx:id="tfConsult"  promptText="Consultation Fee (₹)"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Medicines"    GridPane.rowIndex="2" styleClass="form-label"/>
            <TextField fx:id="tfMedicine" promptText="Medicine Amount (₹)"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Lab Tests"    GridPane.rowIndex="3" styleClass="form-label"/>
            <TextField fx:id="tfLab"      promptText="Lab Amount (₹)"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Discount"     GridPane.rowIndex="4" styleClass="form-label"/>
            <TextField fx:id="tfDiscount" promptText="Discount (₹)"
                       GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label fx:id="lblTotal"    text="Total: ₹0.00"
                   GridPane.rowIndex="5" GridPane.columnIndex="1"
                   styleClass="total-label"/>

            <Label fx:id="lblNet"      text="Net Payable: ₹0.00"
                   GridPane.rowIndex="6" GridPane.columnIndex="1"
                   styleClass="net-label"/>

            <Separator GridPane.rowIndex="7" GridPane.columnIndex="0"
                       GridPane.columnSpan="2"/>

            <Label text="Pay Amount"   GridPane.rowIndex="8" styleClass="form-label"/>
            <TextField fx:id="tfPayAmount" promptText="Amount to Pay (₹)"
                       GridPane.rowIndex="8" GridPane.columnIndex="1"/>

            <Label text="Pay Mode"     GridPane.rowIndex="9" styleClass="form-label"/>
            <ComboBox fx:id="cbPayMode" GridPane.rowIndex="9" GridPane.columnIndex="1"
                      promptText="Payment Mode" maxWidth="Infinity"/>
        </GridPane>

        <HBox spacing="10">
            <Button text="🧾 Generate Bill" fx:id="btnGenerate" onAction="#onGenerate"
                    styleClass="btn-success"/>
            <Button text="✖ Clear"          fx:id="btnClear"    onAction="#onClear"
                    styleClass="btn-secondary"/>
        </HBox>
    </VBox>
</SplitPane>
